# === Supabase (shared with FaîtiereHub) ===
SUPABASE_URL=https://hhnswekjgbxckluqnszo.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# === DeepSeek API — principal LLM (supports multi-key rotation) ===
# Get keys at https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your_deepseek_key_here
# DEEPSEEK_API_KEY_1=sk-...
# DEEPSEEK_API_KEY_2=sk-...
# DEEPSEEK_API_KEY_3=sk-...
# DEEPSEEK_MODEL=deepseek-chat        # deepseek-chat (V3) or deepseek-reasoner (R1)

# === Gemini API — kept for vision / audio transcription only ===
GEMINI_API_KEY=your_gemini_key
# GEMINI_API_KEY_1=
# GEMINI_API_KEY_2=
# GEMINI_API_KEY_3=

# === Optional: DashScope (Qwen) for multi-model debate ===
DASHSCOPE_API_KEY=

# === Optional: KoboCollect ===
KOBO_BASE_URL=
KOBO_TOKEN=

# === Server ===
PORT=8000
FLASK_ENV=production

# === Haroo Platform ===
# Uses the same Supabase instance as FaîtiereHub (SUPABASE_URL + SUPABASE_SERVICE_KEY above)
